{
  "name": "zakat-companion",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "pwa:assets": "node ./scripts/generate-pwa-assets.mjs",
    "prebuild": "pnpm run paraglide:compile",
    "pretypecheck": "pnpm run paraglide:compile",
    "build": "vite build",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx}\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "machine-translate": "inlang machine translate --project project.inlang",
    "wrangler": "wrangler"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/figtree": "^5.2.10",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tanstack/react-router-ssr-query": "^1.166.9",
    "@tanstack/react-start": "^1.166.15",
    "@tanstack/router-plugin": "^1.166.13",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "nitro": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "^5.1.4",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.3",
    "@inlang/cli": "^3.0.0",
    "@inlang/paraglide-js": "^2.18.0",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "pwa-asset-generator": "^8.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "web-vitals": "^5.1.0",
    "wrangler": "^4.90.0"
  }
}
