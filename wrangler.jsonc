{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "zakat-companion",
  "compatibility_date": "2026-05-07",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./src/server.ts",
  "secrets": {
    "required": ["BETTER_AUTH_SECRET", "DATABASE_URL"],
  },
  "observability": {
    "enabled": true,
  },
}
